{
  "name": "dash4devs-platform",
  "version": "0.1.0-alpha",
  "description": "Private SDK for Dash4Devs white-label platforms. Not for public distribution.",
  "private": true,
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "bin": {
    "dash4devs": "./cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./server": {
      "types": "./index.d.ts",
      "import": "./server.js",
      "default": "./server.js"
    },
    "./react": {
      "types": "./react/index.d.ts",
      "import": "./react/index.js",
      "default": "./react/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "server.js",
    "services/",
    "react/",
    "cli/",
    "README.md"
  ],
  "dependencies": {
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "ora": "^8.0.1"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "author": "John Molina from CodeCraft Studios <johnmolina@codecraftstudios.net>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  }
}
